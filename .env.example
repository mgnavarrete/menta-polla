# Copia este archivo a `.env` y ajusta los valores.
#   cp .env.example .env

# Base de datos SQLite (archivo local). En producción puede ser una ruta
# absoluta fuera del proyecto, ej: file:/var/lib/polla/prod.db
DATABASE_URL="file:./dev.db"

# Marca de la app: el nombre que precede a "Polla" en el título y la cabecera.
# Opciones de ejemplo: Menta · Flenta · Oddi (o el que quieras). Reinicia tras cambiar.
BRAND="Menta"

# Secreto para firmar la cookie de sesión.
# Genera uno con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-largo-y-unico"

# PIN del usuario admin (Menta) que se crea con `npm run seed`.
ADMIN_PIN="0902"
