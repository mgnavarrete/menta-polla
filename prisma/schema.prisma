// Polla Mundial 2026 — esquema de datos
// SQLite no soporta enums en Prisma, por eso los campos "phase" y "status"
// son String con valores documentados.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  pinHash     String
  isAdmin     Boolean           @default(false)
  createdAt   DateTime          @default(now())
  predictions Prediction[]
  phaseLocks  PhaseSubmission[]
}

// Una vez que un usuario "guarda" una fase, queda bloqueada: no puede volver
// a editar sus predicciones de esa fase.
model PhaseSubmission {
  id          Int      @id @default(autoincrement())
  userId      Int
  phase       String // GROUP | R32 | R16 | QF | SF | THIRD | FINAL
  submittedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, phase])
}

model Team {
  id           Int          @id @default(autoincrement())
  name         String       @unique
  code         String // sigla de 3 letras (ej. "CHI")
  flag         String // emoji de bandera (respaldo)
  iso          String // slug de flagcdn -> /flags/{iso}.svg (ej. "mx", "gb-sct")
  groupName    String // "A".."L"
  homeMatches  Match[]      @relation("home")
  awayMatches  Match[]      @relation("away")
  wonMatches   Match[]      @relation("winner")
  advancePreds Prediction[] @relation("advance")
}

model Match {
  id           Int          @id @default(autoincrement())
  matchNo      Int          @unique // numero oficial de partido
  phase        String // GROUP | R32 | R16 | QF | SF | THIRD | FINAL
  groupName    String? // solo en fase de grupos
  slotLabel    String? // ej. "1A vs 2B" o "Ganador 73 vs Ganador 74"
  kickoff      DateTime
  homeTeamId   Int?
  awayTeamId   Int?
  homeTeam     Team?        @relation("home", fields: [homeTeamId], references: [id])
  awayTeam     Team?        @relation("away", fields: [awayTeamId], references: [id])
  homeGoals    Int?
  awayGoals    Int?
  // equipo que avanza (solo eliminatorias; resuelve empates por penales)
  winnerTeamId Int?
  winnerTeam   Team?        @relation("winner", fields: [winnerTeamId], references: [id])
  status       String       @default("SCHEDULED") // SCHEDULED | FINISHED
  predictions  Prediction[]
}

model Prediction {
  id            Int      @id @default(autoincrement())
  userId        Int
  matchId       Int
  homeGoals     Int
  awayGoals     Int
  // a quien cree el usuario que avanza (solo eliminatorias)
  advanceTeamId Int?
  points        Int      @default(0)
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id])
  match         Match    @relation(fields: [matchId], references: [id])
  advanceTeam   Team?    @relation("advance", fields: [advanceTeamId], references: [id])

  @@unique([userId, matchId])
}
